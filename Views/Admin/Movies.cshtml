@model List<Movie>
@{
    ViewData["Title"] = "Quản lý phim";
    ViewData["ActiveMenu"] = "Movies";
    Layout = "_AdminLayout";
    var bookingCounts = ViewBag.BookingCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <form method="get" class="d-flex gap-2">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control form-control-sm" placeholder="Tìm phim..." style="width:220px;" />
        <button type="submit" class="btn btn-sm btn-secondary">Tìm</button>
    </form>
    <a asp-action="CreateMovie" class="btn btn-danger btn-sm"><i class="bi bi-plus-lg me-1"></i>Thêm phim</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th style="width:60px;">Poster</th>
                        <th>Tên phim</th>
                        <th>Thể loại</th>
                        <th>Đạo diễn</th>
                        <th>Thời lượng</th>
                        <th>Trạng thái</th>
                        <th>Đặt vé</th>
                        <th>Ngày chiếu</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var movie in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(movie.PosterUrl))
                                {
                                    <img src="@movie.PosterUrl" class="rounded" style="width:40px;height:55px;object-fit:cover;" onerror="this.src='/images/no-poster.jpg'" />
                                }
                                else
                                {
                                    <div class="bg-secondary rounded d-flex align-items-center justify-content-center" style="width:40px;height:55px;"><i class="bi bi-film text-white small"></i></div>
                                }
                            </td>
                            <td><strong>@movie.Title</strong></td>
                            <td><small>@movie.Genre</small></td>
                            <td><small>@movie.Director</small></td>
                            <td><small>@movie.DurationMin phút</small></td>
                            <td>
                                @if (movie.Status == "now_showing")
                                { <span class="badge bg-success">Đang chiếu</span> }
                                else if (movie.Status == "coming_soon")
                                { <span class="badge bg-warning text-dark">Sắp chiếu</span> }
                                else
                                { <span class="badge bg-secondary"><i class="bi bi-eye-slash me-1"></i>Ẩn</span> }
                            </td>
                            <td><small class="text-muted">@movie.ReleaseDate?.ToString("dd/MM/yyyy")</small></td>
                            <td>
                                @{ var count = bookingCounts.GetValueOrDefault(movie.Id, 0); }
                                @if (count > 0)
                                {
                                    <span class="badge bg-warning text-dark" title="Có @count lượt đặt vé chưa hủy">
                                        <i class="bi bi-ticket-perforated me-1"></i>@count
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="EditMovie" asp-route-id="@movie.Id" class="btn btn-sm btn-outline-primary me-1">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" asp-action="DeleteMovie" asp-route-id="@movie.Id" class="d-inline"
                                      onsubmit="return confirmDeleteMovie('@Html.Raw(movie.Title.Replace("'", "\\'"))', @count)">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            title="@(count > 0 ? $"Xóa phim (còn {count} lượt đặt vé)" : "Xóa phim")">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted"><i class="bi bi-film fs-1 d-block mb-2"></i>Không có phim nào</div>
        }
    </div>
</div>

@section Scripts {
<script>
function confirmDeleteMovie(title, bookingCount) {
    if (bookingCount > 0) {
        return confirm('⚠️ Phim "' + title + '" đang có ' + bookingCount + ' lượt đặt vé chưa hủy.\nKhách hàng sẽ được thông báo tự động sau khi xóa.\n\nBạn có chắc chắn muốn xóa không?');
    }
    return confirm('Bạn có chắc muốn xóa phim "' + title + '"?');
}
</script>
}
