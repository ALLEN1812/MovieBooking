@model List<User>
@{
    ViewData["Title"] = "Quản lý người dùng";
    ViewData["ActiveMenu"] = "Users";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <form method="get" class="d-flex gap-2">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control form-control-sm" placeholder="Tìm người dùng..." style="width:220px;" />
        <button type="submit" class="btn btn-sm btn-secondary">Tìm</button>
    </form>
    <a asp-action="CreateUser" class="btn btn-danger btn-sm"><i class="bi bi-person-plus me-1"></i>Thêm người dùng</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Tên</th>
                        <th>Email</th>
                        <th>Điện thoại</th>
                        <th>Vai trò</th>
                        <th>Ngày tạo</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.Id</td>
                            <td><strong>@user.Name</strong></td>
                            <td><small>@user.Email</small></td>
                            <td><small>@user.Phone</small></td>
                            <td>
                                <span class="badge @(user.Role == "admin" ? "bg-danger" : "bg-primary")">
                                    @(user.Role == "admin" ? "Admin" : "Người dùng")
                                </span>
                            </td>
                            <td><small class="text-muted">@user.CreatedAt.ToString("dd/MM/yyyy")</small></td>
                            <td class="text-center">
                                <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary me-1">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" asp-action="DeleteUser" asp-route-id="@user.Id" class="d-inline"
                                      onsubmit="return confirm('Xóa người dùng @user.Name?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
