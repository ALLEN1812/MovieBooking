@model CinemaFormViewModel
@{
    ViewData["Title"] = "Sửa rạp chiếu";
    ViewData["ActiveMenu"] = "Cinemas";
    Layout = "_AdminLayout";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tên rạp <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Địa chỉ</label>
                        <input asp-for="Location" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Hotline</label>
                        <input asp-for="Hotline" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Ảnh rạp</label>
                        <input type="file" asp-for="ImageFile" class="form-control" accept="image/*" onchange="previewImage(this)" />
                        <div id="img-preview" class="mt-2" style="@(string.IsNullOrEmpty(Model.ImageUrl) ? "display:none" : "")">
                            <img id="preview-img" src="@Model.ImageUrl" class="rounded" style="height:120px;object-fit:cover;width:100%;" onerror="this.src='/images/no-poster.jpg'" />
                        </div>
                        <input asp-for="ImageUrl" type="hidden" />
                    </div>
                    <div class="d-flex gap-2 justify-content-end mt-4">
                        <a asp-action="Cinemas" class="btn btn-outline-secondary">Hủy</a>
                        <button type="submit" class="btn btn-danger"><i class="bi bi-check-lg me-1"></i>Lưu thay đổi</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function previewImage(input) {
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = e => {
            document.getElementById('preview-img').src = e.target.result;
            document.getElementById('img-preview').style.display = '';
        };
        reader.readAsDataURL(input.files[0]);
    }
}
</script>
}
