@model UpdateProfileViewModel
@{
    ViewData["Title"] = "Hồ sơ Admin";
    ViewData["ActiveMenu"] = "Profile";
    Layout = "_AdminLayout";
}

<div class="card border-0 shadow-sm" style="max-width:550px;">
    <div class="card-body p-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Email</label>
                <input value="@ViewBag.Email" class="form-control bg-light" disabled />
            </div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold">Họ tên</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Phone" class="form-label fw-semibold">Điện thoại</label>
                <input asp-for="Phone" class="form-control" />
            </div>
            <div class="mb-4">
                <label asp-for="Address" class="form-label fw-semibold">Địa chỉ</label>
                <input asp-for="Address" class="form-control" />
            </div>
            <button type="submit" class="btn btn-danger px-4"><i class="bi bi-save me-2"></i>Lưu thay đổi</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
