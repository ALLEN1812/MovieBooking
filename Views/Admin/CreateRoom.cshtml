@model RoomFormViewModel
@{
    ViewData["Title"] = "Thêm phòng chiếu";
    ViewData["ActiveMenu"] = "Rooms";
    Layout = "_AdminLayout";
}

<div class="card border-0 shadow-sm" style="max-width:500px;">
    <div class="card-body p-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="CinemaId" class="form-label fw-semibold">Rạp <span class="text-danger">*</span></label>
                    <select asp-for="CinemaId" class="form-select" asp-items="@(new SelectList(Model.Cinemas, "Id", "Name"))">
                        <option value="">-- Chọn rạp --</option>
                    </select>
                    <span asp-validation-for="CinemaId" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Name" class="form-label fw-semibold">Tên phòng <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control" placeholder="Phòng 1" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="TotalRows" class="form-label fw-semibold">Số hàng ghế</label>
                    <input asp-for="TotalRows" class="form-control" type="number" min="1" max="26" />
                    <small class="text-muted">Tối đa 26 hàng (A-Z)</small>
                </div>
                <div class="col-md-6">
                    <label asp-for="TotalCols" class="form-label fw-semibold">Số cột ghế</label>
                    <input asp-for="TotalCols" class="form-control" type="number" min="1" max="30" />
                </div>
            </div>
            <p class="text-muted small mt-2"><i class="bi bi-info-circle me-1"></i>Ghế sẽ được tạo tự động. 2 hàng cuối là ghế VIP.</p>
            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-danger"><i class="bi bi-save me-2"></i>Tạo phòng</button>
                <a asp-action="Rooms" class="btn btn-outline-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
