@model ShowtimeFormViewModel
@{
    ViewData["Title"] = "Chỉnh sửa suất chiếu";
    ViewData["ActiveMenu"] = "Showtimes";
    Layout = "_AdminLayout";
}

<div class="card border-0 shadow-sm" style="max-width:600px;">
    <div class="card-body p-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
            <input type="hidden" asp-for="Id" />
            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="MovieId" class="form-label fw-semibold">Phim</label>
                    <select asp-for="MovieId" class="form-select" asp-items="@(new SelectList(Model.Movies, "Id", "Title"))"></select>
                </div>
                <div class="col-12">
                    <label asp-for="RoomId" class="form-label fw-semibold">Phòng chiếu</label>
                    <select asp-for="RoomId" class="form-select" asp-items="@(new SelectList(Model.Rooms, "Id", "Name"))"></select>
                </div>
                <div class="col-md-6">
                    <label asp-for="StartTime" class="form-label fw-semibold">Giờ chiếu</label>
                    <input asp-for="StartTime" class="form-control" type="datetime-local" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Price" class="form-label fw-semibold">Giá vé (₫)</label>
                    <input asp-for="Price" class="form-control" type="number" />
                </div>
                <div class="col-12">
                    <label asp-for="Subtitle" class="form-label fw-semibold">Phụ đề</label>
                    <select asp-for="Subtitle" class="form-select">
                        <option value="Vietsub">Vietsub</option>
                        <option value="Thuyết minh">Thuyết minh</option>
                        <option value="Phụ đề Anh">Phụ đề Anh</option>
                    </select>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-danger"><i class="bi bi-save me-2"></i>Lưu thay đổi</button>
                <a asp-action="Showtimes" class="btn btn-outline-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
