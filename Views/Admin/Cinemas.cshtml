@model List<Cinema>
@{
    ViewData["Title"] = "Quản lý rạp chiếu";
    ViewData["ActiveMenu"] = "Cinemas";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-end mb-3">
    <a asp-action="CreateCinema" class="btn btn-danger btn-sm"><i class="bi bi-plus-lg me-1"></i>Thêm rạp chiếu</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th style="width:60px">Ảnh</th>
                    <th>Tên rạp</th>
                    <th>Địa chỉ</th>
                    <th>Hotline</th>
                    <th>Số phòng</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(c.ImageUrl))
                            {
                                <img src="@c.ImageUrl" class="rounded" style="width:50px;height:35px;object-fit:cover;" onerror="this.src='/images/no-poster.jpg'" />
                            }
                            else
                            {
                                <div class="bg-secondary rounded d-flex align-items-center justify-content-center" style="width:50px;height:35px;">
                                    <i class="bi bi-building text-white small"></i>
                                </div>
                            }
                        </td>
                        <td><strong>@c.Name</strong></td>
                        <td><small class="text-muted">@(c.Location ?? "—")</small></td>
                        <td><small>@(c.Hotline ?? "—")</small></td>
                        <td><span class="badge bg-info text-dark">@c.Rooms.Count phòng</span></td>
                        <td class="text-center">
                            <a asp-action="EditCinema" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" asp-action="DeleteCinema" asp-route-id="@c.Id" class="d-inline"
                                  onsubmit="return confirm('Xóa rạp @c.Name? Tất cả phòng chiếu liên quan sẽ bị xóa.')">
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted"><i class="bi bi-building fs-1 d-block mb-2"></i>Chưa có rạp chiếu nào</div>
        }
    </div>
</div>
