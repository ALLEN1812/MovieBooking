@model UpdateProfileViewModel
@{
    ViewData["Title"] = "Tài khoản của tôi";
}

<div class="container py-4">
    <div class="row">
        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center py-4">
                    <div class="rounded-circle bg-danger bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width:70px;height:70px;">
                        <i class="bi bi-person-fill text-danger fs-2"></i>
                    </div>
                    <h6 class="fw-bold">@User.Identity?.Name</h6>
                    <small class="text-muted">@ViewBag.Email</small>
                </div>
                <div class="list-group list-group-flush">
                    <a asp-action="Account" class="list-group-item list-group-item-action active"><i class="bi bi-person me-2"></i>Thông tin</a>
                    <a asp-action="Bookings" class="list-group-item list-group-item-action"><i class="bi bi-ticket me-2"></i>Lịch sử đặt vé</a>
                    <a asp-action="ChangePassword" class="list-group-item list-group-item-action"><i class="bi bi-lock me-2"></i>Đổi mật khẩu</a>
                </div>
            </div>
        </div>
        <div class="col-md-9">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Thông tin cá nhân</h5>
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show">
                            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Email</label>
                            <input value="@ViewBag.Email" class="form-control bg-light" disabled />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold">Họ và tên</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Phone" class="form-label fw-semibold">Số điện thoại</label>
                            <input asp-for="Phone" class="form-control" placeholder="0901234567" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                        <div class="mb-4">
                            <label asp-for="Address" class="form-label fw-semibold">Địa chỉ</label>
                            <input asp-for="Address" class="form-control" placeholder="Địa chỉ của bạn" />
                        </div>
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-save me-2"></i>Lưu thay đổi
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
