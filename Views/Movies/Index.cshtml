@model List<Movie>
@{
    ViewData["Title"] = "Danh sách phim";
    var status = ViewBag.Status as string;
    var search = ViewBag.Search as string;
}

<div class="bg-dark text-white py-4">
    <div class="container">
        <h2 class="fw-bold mb-0">
            @(status == "coming_soon" ? "Phim Sắp Chiếu" : status == "now_showing" ? "Phim Đang Chiếu" : "Tất Cả Phim")
        </h2>
    </div>
</div>

<div class="container py-4">
    <!-- Filter Bar -->
    <form method="get" class="row g-2 mb-4">
        <div class="col-md-4">
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" name="search" value="@search" class="form-control" placeholder="Tìm phim..." />
            </div>
        </div>
        <div class="col-md-3">
            <select name="status" class="form-select" onchange="this.form.submit()">
                <option value="" selected="@(string.IsNullOrEmpty(status))">Tất cả</option>
                <option value="now_showing" selected="@(status == "now_showing")">Đang chiếu</option>
                <option value="coming_soon" selected="@(status == "coming_soon")">Sắp chiếu</option>
            </select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-danger">Tìm kiếm</button>
            @if (!string.IsNullOrEmpty(search) || !string.IsNullOrEmpty(status))
            {
                <a asp-controller="Movies" asp-action="Index" class="btn btn-outline-secondary ms-1">Xóa bộ lọc</a>
            }
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-film text-muted" style="font-size:4rem;"></i>
            <h5 class="mt-3 text-muted">Không tìm thấy phim nào</h5>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var movie in Model)
            {
                <div class="col-6 col-md-4 col-lg-3 col-xl-2">
                    <div class="movie-card card border-0 shadow-sm h-100 overflow-hidden">
                        <a asp-controller="Movies" asp-action="Details" asp-route-id="@movie.Id" class="text-decoration-none text-dark">
                            <div class="position-relative">
                                @if (!string.IsNullOrEmpty(movie.PosterUrl))
                                {
                                    <img src="@movie.PosterUrl" class="card-img-top" alt="@movie.Title" style="height:280px;object-fit:cover;" onerror="this.src='/images/no-poster.jpg'" />
                                }
                                else
                                {
                                    <div class="bg-secondary d-flex align-items-center justify-content-center" style="height:280px;">
                                        <i class="bi bi-film text-white fs-1"></i>
                                    </div>
                                }
                                @if (movie.Status == "coming_soon")
                                {
                                    <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-2">Sắp chiếu</span>
                                }
                                else
                                {
                                    <span class="badge bg-success position-absolute top-0 end-0 m-2">Đang chiếu</span>
                                }
                                <div class="poster-overlay position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center">
                                    <span class="btn btn-danger btn-sm">
                                        @(movie.Status == "now_showing" ? "Đặt vé" : "Chi tiết")
                                    </span>
                                </div>
                            </div>
                            <div class="card-body p-2">
                                <h6 class="mb-1 fw-bold text-truncate" title="@movie.Title">@movie.Title</h6>
                                <small class="text-muted">@movie.Genre</small>
                                <div class="d-flex justify-content-between mt-1">
                                    <small class="text-muted"><i class="bi bi-clock me-1"></i>@movie.DurationMin phút</small>
                                    @if (movie.ReleaseDate.HasValue)
                                    {
                                        <small class="text-muted">@movie.ReleaseDate.Value.Year</small>
                                    }
                                </div>
                            </div>
                        </a>
                    </div>
                </div>
            }
        </div>
        <p class="text-muted mt-3">Hiển thị @Model.Count phim</p>
    }
</div>
