@model OnlineMovieBooking.Models.Notification
@{
    ViewData["Title"] = Model.Title;
    var isCancel   = Model.Title.Contains("hủy") || Model.Title.Contains("Hủy");
    var isConfirm  = Model.Title.Contains("thành công") || Model.Title.Contains("xác nhận") || Model.Title.Contains("Xác nhận");
    var (iconClass, alertClass) = isCancel  ? ("bi-x-circle-fill text-danger",  "alert-danger")
                                : isConfirm ? ("bi-check-circle-fill text-success", "alert-success")
                                :             ("bi-bell-fill text-primary", "alert-info");
}

<div class="bg-dark text-white py-3">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a asp-action="Index" class="text-muted text-decoration-none">Thông báo</a></li>
            </ol>
        </nav>
        <h5 class="mb-0 fw-bold">Chi tiết thông báo</h5>
    </div>
</div>

<div class="container py-4" style="max-width:640px;">
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-4">

            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center flex-shrink-0"
                     style="width:56px;height:56px;">
                    <i class="bi @iconClass fs-3"></i>
                </div>
                <div>
                    <h5 class="fw-bold mb-1">@Model.Title</h5>
                    <small class="text-muted"><i class="bi bi-clock me-1"></i>@Model.CreatedAt.ToString("HH:mm - dd/MM/yyyy")</small>
                </div>
            </div>

            <div class="alert @alertClass rounded-3">
                <p class="mb-0">@Model.Message</p>
            </div>

            @if (Model.Booking != null)
            {
                <div class="card bg-light border-0 rounded-3 p-3 mt-3">
                    <div class="small text-muted mb-2 fw-semibold">Thông tin đơn đặt vé</div>
                    <div class="row g-2 small">
                        <div class="col-6">
                            <div class="text-muted">Mã đặt vé</div>
                            <div class="fw-bold text-danger">#@Model.Booking.Id</div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted">Phim</div>
                            <div class="fw-semibold">@Model.Booking.Showtime?.Movie?.Title</div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted">Suất chiếu</div>
                            <div>@Model.Booking.Showtime?.StartTime.ToString("HH:mm dd/MM/yyyy")</div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted">Tổng tiền</div>
                            <div class="fw-bold">@Model.Booking.TotalPrice.ToString("N0") ₫</div>
                        </div>
                    </div>
                </div>

                @if (Model.Booking.Status == "confirmed")
                {
                    <div class="d-flex gap-2 mt-3">
                        <a asp-controller="Booking" asp-action="Invoice" asp-route-id="@Model.Booking.Id"
                           class="btn btn-outline-danger btn-sm" target="_blank">
                            <i class="bi bi-file-earmark-pdf me-1"></i>Tải hoá đơn
                        </a>
                    </div>
                }
            }

        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Quay lại thông báo
        </a>
    </div>
</div>
