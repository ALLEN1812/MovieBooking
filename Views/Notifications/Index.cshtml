@model List<OnlineMovieBooking.Models.Notification>
@{
    ViewData["Title"] = "Thông báo";
}

<div class="bg-dark text-white py-3">
    <div class="container"><h5 class="mb-0 fw-bold"><i class="bi bi-bell-fill me-2"></i>Thông báo của bạn</h5></div>
</div>

<div class="container py-4" style="max-width:720px;">
    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-bell-slash" style="font-size:3.5rem;"></i>
            <p class="mt-3">Chưa có thông báo nào</p>
        </div>
    }
    else
    {
        <div class="list-group shadow-sm">
            @foreach (var n in Model)
            {
                var icon = (n.Title.Contains("hủy") || n.Title.Contains("Hủy")) ? "bi-x-circle-fill text-danger"
                         : (n.Title.Contains("thành công") || n.Title.Contains("xác nhận") || n.Title.Contains("Xác nhận")) ? "bi-check-circle-fill text-success"
                         : "bi-bell-fill text-primary";
                <a asp-action="Detail" asp-route-id="@n.Id"
                   class="list-group-item list-group-item-action d-flex gap-3 py-3 @(!n.IsRead ? "bg-light" : "")">
                    <div class="flex-shrink-0 mt-1"><i class="bi @icon fs-5"></i></div>
                    <div class="flex-grow-1 overflow-hidden">
                        <div class="d-flex justify-content-between align-items-start">
                            <span class="@(!n.IsRead ? "fw-bold" : "fw-semibold")">@n.Title</span>
                            <small class="text-muted ms-2 text-nowrap">@n.CreatedAt.ToString("dd/MM HH:mm")</small>
                        </div>
                        <p class="mb-0 small text-muted text-truncate">@n.Message</p>
                    </div>
                    @if (!n.IsRead)
                    {
                        <span class="flex-shrink-0 align-self-center rounded-pill bg-danger" style="width:8px;height:8px;display:inline-block;"></span>
                    }
                </a>
            }
        </div>
    }
</div>
