<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MovieBooking</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold text-danger fs-4" asp-controller="Home" asp-action="Index">
                <i class="bi bi-film me-2"></i>MovieBooking
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMain">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Phim</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Movies" asp-action="Index" asp-route-status="now_showing"><i class="bi bi-play-circle me-2"></i>Phim đang chiếu</a></li>
                            <li><a class="dropdown-item" asp-controller="Movies" asp-action="Index" asp-route-status="coming_soon"><i class="bi bi-clock me-2"></i>Phim sắp chiếu</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Movies" asp-action="Schedule">Lịch chiếu</a>
                    </li>
                </ul>
                <ul class="navbar-nav ms-auto align-items-center gap-1">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link position-relative" asp-controller="Notifications" asp-action="Index" title="Thông báo">
                                <i class="bi bi-bell-fill fs-5"></i>
                                <span id="notif-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display:none"></span>
                            </a>
                        </li>
                        @if (User.IsInRole("admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Index">
                                    <i class="bi bi-speedometer2 me-1"></i>Admin
                                </a>
                            </li>
                        }
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-1" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle fs-5"></i>
                                <span>@User.Identity.Name</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-controller="Profile" asp-action="Account"><i class="bi bi-person me-2"></i>Tài khoản</a></li>
                                <li><a class="dropdown-item" asp-controller="Profile" asp-action="Bookings"><i class="bi bi-ticket me-2"></i>Lịch sử đặt vé</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form method="post" asp-controller="Account" asp-action="Logout">
                                        <button type="submit" class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-danger btn-sm" asp-controller="Account" asp-action="Register">Đăng ký</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="footer-main mt-5">
        <!-- Top footer -->
        <div class="footer-top py-5">
            <div class="container">
                <div class="row g-4">
                    <!-- Brand -->
                    <div class="col-lg-4 col-md-6">
                        <div class="footer-brand mb-3">
                            <i class="bi bi-film me-2 text-danger fs-4"></i>
                            <span class="fw-bold fs-4 text-white">MovieBooking</span>
                        </div>
                        <p class="footer-desc mb-3">Hệ thống đặt vé xem phim trực tuyến — chọn phim yêu thích, đặt chỗ ngay, trải nghiệm rạp chiếu tốt nhất tại Quy Nhơn.</p>
                        <div class="d-flex gap-2 mt-3">
                            <a href="#" class="footer-social" title="Facebook"><i class="bi bi-facebook"></i></a>
                            <a href="#" class="footer-social" title="YouTube"><i class="bi bi-youtube"></i></a>
                            <a href="#" class="footer-social" title="Instagram"><i class="bi bi-instagram"></i></a>
                            <a href="#" class="footer-social" title="TikTok"><i class="bi bi-tiktok"></i></a>
                        </div>
                    </div>

                    <!-- Quick links -->
                    <div class="col-lg-2 col-md-6 col-6">
                        <h6 class="footer-heading">Phim</h6>
                        <ul class="list-unstyled footer-links">
                            <li><a asp-controller="Movies" asp-action="Index" asp-route-status="now_showing"><i class="bi bi-play-circle me-1"></i>Đang chiếu</a></li>
                            <li><a asp-controller="Movies" asp-action="Index" asp-route-status="coming_soon"><i class="bi bi-clock me-1"></i>Sắp chiếu</a></li>
                            <li><a asp-controller="Movies" asp-action="Schedule"><i class="bi bi-calendar3 me-1"></i>Lịch chiếu</a></li>
                        </ul>
                    </div>

                    <!-- Account links -->
                    <div class="col-lg-2 col-md-6 col-6">
                        <h6 class="footer-heading">Tài khoản</h6>
                        <ul class="list-unstyled footer-links">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <li><a asp-controller="Profile" asp-action="Account"><i class="bi bi-person me-1"></i>Hồ sơ</a></li>
                                <li><a asp-controller="Profile" asp-action="Bookings"><i class="bi bi-ticket me-1"></i>Lịch sử vé</a></li>
                                <li><a asp-controller="Notifications" asp-action="Index"><i class="bi bi-bell me-1"></i>Thông báo</a></li>
                            }
                            else
                            {
                                <li><a asp-controller="Account" asp-action="Login"><i class="bi bi-box-arrow-in-right me-1"></i>Đăng nhập</a></li>
                                <li><a asp-controller="Account" asp-action="Register"><i class="bi bi-person-plus me-1"></i>Đăng ký</a></li>
                            }
                        </ul>
                    </div>

                    <!-- Contact -->
                    <div class="col-lg-4 col-md-6">
                        <h6 class="footer-heading">Liên hệ & Hỗ trợ</h6>
                        <ul class="list-unstyled footer-contact">
                            <li>
                                <i class="bi bi-geo-alt-fill text-danger"></i>
                                <span>268 Lê Lợi, Quy Nhơn, Bình Định</span>
                            </li>
                            <li>
                                <i class="bi bi-telephone-fill text-danger"></i>
                                <a href="tel:0394945853">0394 945 853</a>
                            </li>
                            <li>
                                <i class="bi bi-envelope-fill text-danger"></i>
                                <a href="mailto:support@moviebooking.vn">support@moviebooking.vn</a>
                            </li>
                            <li>
                                <i class="bi bi-clock-fill text-danger"></i>
                                <span>Hỗ trợ: 8:00 – 22:00 hàng ngày</span>
                            </li>
                        </ul>
                        <div class="footer-payment mt-3">
                            <small class="text-secondary d-block mb-2">Chấp nhận thanh toán</small>
                            <div class="d-flex gap-2 align-items-center flex-wrap">
                                <span class="badge bg-secondary py-2 px-3"><i class="bi bi-cash-coin me-1"></i>Tiền mặt</span>
                                <span class="badge bg-secondary py-2 px-3"><i class="bi bi-qr-code-scan me-1"></i>MoMo</span>
                                <span class="badge bg-secondary py-2 px-3"><i class="bi bi-bank me-1"></i>VNPay</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bottom bar -->
        <div class="footer-bottom py-3">
            <div class="container">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                    <p class="mb-0 small text-secondary">&copy; 2025 MovieBooking Quy Nhơn. Bảo lưu mọi quyền.</p>
                    <p class="mb-0 small text-secondary">Thiết kế với <i class="bi bi-heart-fill text-danger mx-1"></i> tại Việt Nam</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <script>
            fetch('/Notifications/UnreadCount')
                .then(r => r.json())
                .then(data => {
                    if (data.count > 0) {
                        const badge = document.getElementById('notif-badge');
                        if (badge) { badge.textContent = data.count; badge.style.display = ''; }
                    }
                });
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
