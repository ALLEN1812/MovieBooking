<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin | MovieBooking</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { background-color: #f0f2f5; }
        .sidebar { width: 260px; min-height: 100vh; background: #1a1a2e; position: fixed; top: 0; left: 0; z-index: 1000; transition: all .3s; }
        .sidebar .brand { padding: 1.2rem 1.5rem; border-bottom: 1px solid rgba(255,255,255,.1); }
        .sidebar .nav-link { color: rgba(255,255,255,.7); padding: .65rem 1.5rem; display: flex; align-items: center; gap: .75rem; border-radius: 0; transition: .2s; font-size: .95rem; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { color: #fff; background: rgba(255,255,255,.1); }
        .sidebar .nav-link i { font-size: 1.1rem; width: 1.4rem; }
        .sidebar .nav-section { padding: .5rem 1.5rem .25rem; font-size: .7rem; text-transform: uppercase; letter-spacing: 1px; color: rgba(255,255,255,.3); margin-top: .5rem; }
        .admin-content { margin-left: 260px; padding: 1.5rem; min-height: 100vh; }
        .top-bar { background: #fff; border-bottom: 1px solid #e0e0e0; padding: .8rem 1.5rem; margin: -1.5rem -1.5rem 1.5rem; display: flex; justify-content: space-between; align-items: center; }
        @@media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.show { transform: translateX(0); }
            .admin-content { margin-left: 0; }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="sidebar d-flex flex-column">
        <div class="brand">
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
                <span class="text-danger fw-bold fs-5"><i class="bi bi-film me-2"></i>MovieBooking</span>
            </a>
            <div class="text-muted small mt-1">Quản trị hệ thống</div>
        </div>
        <nav class="flex-grow-1 py-2">
            <span class="nav-section">Tổng quan</span>
            <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Admin" asp-action="Index">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>

            <span class="nav-section">Quản lý</span>
            <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "Movies" ? "active" : "")" asp-controller="Admin" asp-action="Movies">
                <i class="bi bi-film"></i> Phim
            </a>
            <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "Showtimes" ? "active" : "")" asp-controller="Admin" asp-action="Showtimes">
                <i class="bi bi-calendar-event"></i> Suất chiếu
            </a>
            <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "Cinemas" ? "active" : "")" asp-controller="Admin" asp-action="Cinemas">
                <i class="bi bi-geo-alt"></i> Rạp chiếu
            </a>
            <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "Rooms" ? "active" : "")" asp-controller="Admin" asp-action="Rooms">
                <i class="bi bi-building"></i> Phòng chiếu
            </a>
            <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "Bookings" ? "active" : "")" asp-controller="Admin" asp-action="Bookings">
                <i class="bi bi-ticket-perforated"></i> Đặt vé
            </a>
            <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "Users" ? "active" : "")" asp-controller="Admin" asp-action="Users">
                <i class="bi bi-people"></i> Người dùng
            </a>

            <span class="nav-section">Tài khoản</span>
            <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "Profile" ? "active" : "")" asp-controller="Admin" asp-action="Profile">
                <i class="bi bi-person-gear"></i> Hồ sơ
            </a>
            <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "Password" ? "active" : "")" asp-controller="Admin" asp-action="ChangePassword">
                <i class="bi bi-lock"></i> Đổi mật khẩu
            </a>
        </nav>
        <div class="p-3 border-top border-secondary">
            <div class="d-flex align-items-center gap-2 mb-2">
                <i class="bi bi-person-circle text-light fs-4"></i>
                <div>
                    <div class="text-light small fw-bold">@User.Identity?.Name</div>
                    <div class="text-muted" style="font-size:.75rem">Quản trị viên</div>
                </div>
            </div>
            <form method="post" asp-controller="Account" asp-action="Logout">
                <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                    <i class="bi bi-box-arrow-right me-1"></i>Đăng xuất
                </button>
            </form>
        </div>
    </div>

    <div class="admin-content">
        <div class="top-bar">
            <div class="d-flex align-items-center gap-2">
                <button class="btn btn-sm btn-outline-secondary d-lg-none" onclick="document.querySelector('.sidebar').classList.toggle('show')">
                    <i class="bi bi-list"></i>
                </button>
                <h5 class="mb-0 fw-bold">@ViewData["Title"]</h5>
            </div>
            <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-secondary" target="_blank">
                <i class="bi bi-box-arrow-up-right me-1"></i>Xem trang
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Warning"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Warning"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
